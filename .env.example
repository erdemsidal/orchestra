# ═══════════════════════════════════════════════════════
# PostgreSQL
# ═══════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saas_db
DB_USERNAME=postgres
DB_PASSWORD=changeme_strong_password

# ═══════════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379

# ═══════════════════════════════════════════════════════
# JWT — ÖNEMLİ: Production'da mutlaka güçlü secret kullan
# Minimum 64 karakter, HS512 için en az 512-bit key
# Oluşturmak için: openssl rand -base64 64
# ═══════════════════════════════════════════════════════
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64_to_generate_a_strong_secret_key_here

# ═══════════════════════════════════════════════════════
# Sentry — https://sentry.io adresinden DSN al
# ═══════════════════════════════════════════════════════
SENTRY_DSN=

# ═══════════════════════════════════════════════════════
# Spring Profile (dev | prod)
# ═══════════════════════════════════════════════════════
SPRING_PROFILES_ACTIVE=dev
