# ═══════════════════════════════════════════════════════
# PostgreSQL
# ═══════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orchestra_db
DB_USERNAME=postgres
DB_PASSWORD=changeme_strong_password

# ═══════════════════════════════════════════════════════
# Redis (Faz 2'de cache için kullanılacak)
# ═══════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379

# ═══════════════════════════════════════════════════════
# Spring Profile (dev | prod)
# ═══════════════════════════════════════════════════════
SPRING_PROFILES_ACTIVE=dev
